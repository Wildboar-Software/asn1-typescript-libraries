{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "declaration": true,
    "types": [
      "node"
    ],
    "strictNullChecks": false
  },
  "exclude": [
    "**/*.spec.mts",
    "vite.config.ts",
    "vite.config.mts",
    "vitest.config.ts",
    "vitest.config.mts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.js",
    "src/**/*.spec.js",
    "src/**/*.test.mts",
    "src/**/*.spec.mts",
    "src/**/*.test.mjs",
    "src/**/*.spec.mjs",
  ],
  "include": [
    "**/*.mts"
  ]
}
